# Copy this file to .env and fill in real values. NEVER commit the real .env.

# PostgreSQL connection string (Neon, Supabase, RDS, local, etc.)
# postgres:// and postgresql:// are auto-converted to the asyncpg driver.
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# JWT signing secret — set a long random value in production.
SECRET_KEY=change_me_to_a_long_random_secret
